# Twitter API Credentials (OAuth 1.0a User Context)
# Get these from https://developer.twitter.com/en/portal/dashboard
TWITTER_API_KEY=your_api_key_here
TWITTER_API_SECRET=your_api_secret_here
TWITTER_ACCESS_TOKEN=your_access_token_here
TWITTER_ACCESS_TOKEN_SECRET=your_access_token_secret_here

# Optional: Customize the API endpoint
# API_ENDPOINT=https://mg-api-moonsuite-staging.fly.dev/tokens/trending-tokens

# Optional: Customize blocked tokens (comma-separated)
# BLOCKED_SYMBOLS=SOL,JUP,bSOL,TRUMP,Bonk,USDC,USDT,RAY,ORCA,mSOL,jitoSOL,stSOL
